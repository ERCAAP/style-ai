rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection - public read, authenticated write for own data
    match /users/{userId} {
      allow read: if true; // Public read for referral system
      allow create: if isAuthenticated();
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // User Analytics - public read (for analytics dashboard), system write only
    match /userAnalytics/{userId} {
      allow read: if true; // Public read for web dashboard
      allow write: if false; // Only via Cloud Functions or Admin SDK
    }

    // Referral Events - authenticated read, system write only
    match /referralEvents/{eventId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only via Cloud Functions or Admin SDK
    }

    // Deeplink Tracking - public read and create (for web tracking)
    match /deeplinkTracking/{trackingId} {
      allow read: if true;
      allow create: if true; // Anyone can track a click
      allow update: if true; // Allow conversion updates
      allow delete: if false;
    }

    // Wardrobe items - user-specific access
    match /wardrobes/{userId}/items/{itemId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // User preferences - user-specific access
    match /userPreferences/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // Templates - public read, admin write
    match /templates/{templateId} {
      allow read: if true;
      allow write: if false; // Only admins
    }

    // Jobs/Tasks - user-specific access
    match /jobs/{jobId} {
      allow read: if isAuthenticated() &&
                     (resource.data.userId == request.auth.uid ||
                      resource.data.createdBy == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
                       (resource.data.userId == request.auth.uid ||
                        resource.data.createdBy == request.auth.uid);
      allow delete: if isAuthenticated() &&
                       (resource.data.userId == request.auth.uid ||
                        resource.data.createdBy == request.auth.uid);
    }

    // Analysis results - user-specific access
    match /analyses/{analysisId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

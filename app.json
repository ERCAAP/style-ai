{
  "expo": {
    "name": "BOHO",
    "slug": "style-ai",
    "version": "30.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "styleai",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "owner": "holepixai",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.outfit.planner.app",
      "buildNumber": "30",
      "googleServicesFile": "./GoogleService-Info.plist",
      "associatedDomains": [
        "applinks:bohoapp.online",
        "applinks:www.bohoapp.online"
      ],
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Camera access is required to analyze your outfits.",
        "NSPhotoLibraryUsageDescription": "Photo library access is required to select your outfit photos.",
        "NSPhotoLibraryAddUsageDescription": "Photo library access is required to save your analysis results.",
        "UIBackgroundModes": [
          "remote-notification",
          "fetch",
          "processing"
        ],
        "BGTaskSchedulerPermittedIdentifiers": [
          "com.outfit.planner.app.refresh",
          "com.outfit.planner.app.processing"
        ]
      }
    },
    "android": {
      "package": "com.outfit.planner.app",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "bohoapp.online",
              "pathPrefix": "/user"
            },
            {
              "scheme": "https",
              "host": "www.bohoapp.online",
              "pathPrefix": "/user"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.FOREGROUND_SERVICE"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1a1a2e"
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Photo library access is required to select your outfit photos.",
          "cameraPermission": "Camera access is required to analyze your outfits."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Camera access is required to take photos of your outfits."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#6366F1",
          "sounds": [],
          "mode": "production"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 34,
            "minSdkVersion": 24,
            "buildToolsVersion": "35.0.0",
            "usesCleartextTraffic": true
          },
          "ios": {
            "deploymentTarget": "15.1",
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "c5decddc-66d3-46fb-9539-1500fa83802a"
      },
      "router": {}
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}

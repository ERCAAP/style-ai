# Firebase Configuration
# Get these values from Firebase Console > Project Settings
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# OpenAI Configuration
# IMPORTANT: OpenAI API key is now configured in Firebase Functions (server-side)
# Run: firebase functions:config:set openai.key="your_openai_api_key"
# The client no longer needs the API key directly for security reasons

# EachLabs Configuration
# Get this from EachLabs dashboard
EXPO_PUBLIC_EACHLABS_API_KEY=your_eachlabs_api_key

# RevenueCat Configuration
# Get these from RevenueCat Dashboard > Project Settings > API Keys
EXPO_PUBLIC_REVENUECAT_IOS_KEY=your_revenuecat_ios_api_key
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=your_revenuecat_android_api_key
